# Python
.venv/
__pycache__/
*.pyc

# Runtime data — data/.gitkeep is tracked to preserve the directory in git
*.sqlite
*.sqlite3
*.db

# Runtime data — data/.gitkeep is tracked to preserve the directory in git
data/*.json
data/*.jsonl

# Generated deploy/diagnostic snapshot (not source documentation)
docs/current/RAVEN_DOCKER_SNAPSHOT.md

# Secrets
.env

# TinyTuya wizard output (local keys; never commit)
tinytuya.json
devices.json
snapshot.json
tuya-raw.json

# Finch local operator config (store location, non-secret)
data/finch_config.json
data/finch_tokens.json

# Editor / OS
.vscode/
.DS_Store
Thumbs.db

# Runtime logs (auto-created by main.py)
logs/

# Probe debug artefacts (HTML snapshots, screenshots saved by experiment scripts)
experiments/debug/

# Simply Fresh Kitchen probe session + run artifacts
experiments/simplyfresh_probe/.auth/
experiments/simplyfresh_probe/artifacts/

# Kestrel probe runtime data (SQLite, status JSON, debug artifacts)
data/kestrel/
data/telemetry/
data/kestrel_nest_history.jsonl
data/kestrel_tuya_power_history.jsonl
data/raven_metrics_history.jsonl
*.trace.zip
