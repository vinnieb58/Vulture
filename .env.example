# Vulture environment variables
# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# -----------------------------------------------------------------------
# Discord webhook — used by the v1.0 alert notifier (engine/notifier.py)
# Create at: Discord channel settings > Integrations > Webhooks
# -----------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# -----------------------------------------------------------------------
# Discord bot token — used by discord_bot.py
# Create at: https://discord.com/developers/applications > Bot > Reset Token
# Required scopes when inviting: bot, applications.commands
# -----------------------------------------------------------------------
DISCORD_BOT_TOKEN=your-bot-token-here

# -----------------------------------------------------------------------
# Discord guild (server) ID — optional
# Set this during development for instant slash command registration.
# Leave blank for global registration (propagates in ~1 hour).
# Find it: Discord > right-click server > Copy Server ID (dev mode must be on)
# -----------------------------------------------------------------------
DISCORD_GUILD_ID=

# -----------------------------------------------------------------------
# Hunt source for the scheduled runner (main.py)
#   yaml   — load from config/hunts.yaml only  (default; v1.0 behavior)
#   db     — load from SQLite hunts table only  (v2.0 Discord-managed hunts)
#   mixed  — load both; YAML wins on name collision
# -----------------------------------------------------------------------
VULTURE_HUNT_SOURCE=db

# -----------------------------------------------------------------------
# Finch grocery assistant (finch/) — Kroger API credentials
# Register at: https://developer.kroger.com/
# Never commit real values; keep in .env only.
# -----------------------------------------------------------------------
FINCH_KROGER_CLIENT_ID=
FINCH_KROGER_CLIENT_SECRET=
# Optional override — prefer: python -m finch.locations <zip> --save
FINCH_KROGER_LOCATION_ID=
# Required for cart OAuth — must match Kroger developer app redirect URI
FINCH_KROGER_REDIRECT_URI=http://localhost:8765/callback
# Optional debug override — prefer tokens from python -m finch.auth (data/finch_tokens.json)
FINCH_KROGER_USER_ACCESS_TOKEN=
# Set true only after aliases pinned and python -m finch.auth completed
FINCH_LIVE_CART=
FINCH_KROGER_CART_MODALITY=pickup
# Required for Finch local API (finch/api.py) — long random string, localhost only
FINCH_API_KEY=
# Finch local API base URL (used by finch_whatsapp bridge)
FINCH_API_BASE_URL=http://127.0.0.1:8091

# -----------------------------------------------------------------------
# Finch WhatsApp bridge (finch_whatsapp/) — Meta Cloud API webhook
# Callback URL must be reachable by Meta (Tailscale funnel, reverse proxy, etc.)
# -----------------------------------------------------------------------
FINCH_WHATSAPP_VERIFY_TOKEN=
FINCH_WHATSAPP_ACCESS_TOKEN=
FINCH_WHATSAPP_PHONE_NUMBER_ID=
# Comma-separated E.164 digits without + (e.g. 15551234567)
FINCH_WHATSAPP_ALLOWED_NUMBERS=
# Optional bind overrides for python -m finch_whatsapp.app
FINCH_WHATSAPP_HOST=127.0.0.1
FINCH_WHATSAPP_PORT=8092

# -----------------------------------------------------------------------
# Finch Telegram bridge (finch_telegram/) — Bot API long polling
# Create bot via @BotFather; leave ALLOWED_USER_IDS blank initially to log your user ID
# -----------------------------------------------------------------------
FINCH_TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs (e.g. 123456789). Blank logs sender IDs on Raven.
FINCH_TELEGRAM_ALLOWED_USER_IDS=
# Optional getUpdates long-poll timeout in seconds
FINCH_TELEGRAM_POLL_TIMEOUT=30

# -----------------------------------------------------------------------
# Kestrel energy probe (experiments/kestrel/) — Smart Meter Texas
# Disabled by default; does not affect Vulture/Crow startup.
# -----------------------------------------------------------------------
KESTREL_ENABLED=false
KESTREL_SMT_USERNAME=
KESTREL_SMT_PASSWORD=
KESTREL_SMT_ACCOUNT_ID=
KESTREL_DATA_DIR=data/kestrel
KESTREL_DB_PATH=data/kestrel/kestrel.db
KESTREL_LOOKBACK_DAYS=7
KESTREL_HEADLESS=true
KESTREL_LOG_LEVEL=INFO
